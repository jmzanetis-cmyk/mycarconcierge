{
  "name": "my-car-concierge",
  "version": "1.0.0",
  "description": "My Car Concierge - Automotive Service Marketplace",
  "main": "electron/main.js",
  "scripts": {
    "start": "node www/server.js",
    "test": "bash scripts/run-function-tests.sh",
    "smoke": "node scripts/smoke-test.mjs",
    "stress:new": "bash scripts/run-new-stress-tests.sh",
    "generate:bgc-pricing": "node scripts/generate-bgc-pricing.js",
    "check:www-syntax": "for f in www/*.js; do case \"$f\" in www/stress-test-*.js) continue;; esac; node -c \"$f\" || exit 1; done",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "electron": "electron .",
    "electron:dev": "electron .",
    "build:www": "mkdir -p www && cp -r *.html *.png manifest.json pwa-init.js sw.js supabaseclient.js icons www/",
    "cap:sync": "npx cap sync && bash scripts/clean-mobile-bundle.sh && bash scripts/verify-mobile-bundle.sh",
    "cap:sync:raw": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mobile:clean": "bash scripts/clean-mobile-bundle.sh",
    "mobile:verify": "bash scripts/verify-mobile-bundle.sh",
    "ios:run": "bash scripts/ios-run.sh",
    "ios:prep": "bash scripts/ios-build.sh",
    "ios:store": "bash build-ios.sh",
    "build:mac": "npm run build:www && electron-builder --mac",
    "build:win": "npm run build:www && electron-builder --win",
    "build:linux": "npm run build:www && electron-builder --linux",
    "build:all": "npm run build:www && electron-builder --mac --win --linux"
  },
  "keywords": [
    "automotive",
    "service",
    "marketplace",
    "pwa",
    "electron",
    "capacitor"
  ],
  "author": "My Car Concierge",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@aparajita/capacitor-biometric-auth": "^9.1.2",
    "@capacitor/android": "^7.4.4",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/geolocation": "^7.1.8",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/push-notifications": "^7.0.0",
    "@google-cloud/vision": "^5.3.4",
    "@google/genai": "^1.42.0",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.45.0",
    "esbuild": "^0.27.3",
    "netlify-cli": "^23.12.3",
    "openai": "^4.50.0",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "stripe": "^15.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-unicorn": "^64.0.0"
  },
  "build": {
    "appId": "co.mycarconcierge.app",
    "productName": "My Car Concierge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "www/**/*",
      "electron/**/*",
      "icons/**/*"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icons/icon-512.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/icon-512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

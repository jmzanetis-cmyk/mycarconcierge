# =============================================================================
# My Car Concierge — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# =============================================================================
# SUPABASE
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-key
# Secret used to verify Supabase webhook signatures
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Admin email to alert when Stripe key is approaching expiry
STRIPE_KEY_EXPIRY_ADMIN_EMAIL=ops@example.com

# =============================================================================
# TWILIO (SMS / Voice / Verify)
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public URL Twilio posts inbound SMS/calls to (your Netlify site URL)
TWILIO_INBOUND_PUBLIC_URL=https://your-site.netlify.app
# Set to "true" to validate Twilio webhook signatures in production
TWILIO_SIGNATURE_REQUIRED=true

# =============================================================================
# EMAIL — RESEND
# =============================================================================
RESEND_API_KEY=re_...
# From address for transactional email (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@example.com
MCC_FROM_EMAIL=noreply@example.com
# Admin destination for operational alerts
ADMIN_EMAIL=admin@example.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com
ADMIN_ALERT_EMAIL=admin@example.com
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# =============================================================================
# ANTHROPIC / AI AGENTS
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# Secondary key used by the agent fleet (agent-fleet-runtime.js prefers this)
ANTHROPIC_API_KEY_MCC_FLEET1=sk-ant-...
# Minimum confidence score (0–1) before an AI action auto-executes
AI_CONFIDENCE_THRESHOLD=0.75
# Maximum cents the AI may auto-refund without human review
AI_MAX_AUTO_REFUND=5000

# =============================================================================
# GOOGLE / GEMINI
# =============================================================================
GOOGLE_API_KEY=AIza...
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_VISION_API_KEY=AIza...
GEMINI_API_KEY=AIza...

# =============================================================================
# HUBSPOT (CRM sync)
# =============================================================================
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token

# =============================================================================
# APOLLO (Outbound Lead Discovery)
# =============================================================================
APOLLO_API_KEY=your-apollo-api-key

# =============================================================================
# BACKGROUND CHECKS (BGC)
# =============================================================================
BGC_API_BASE=https://api.bgc-provider.com/v1
BGC_API_TOKEN=your-bgc-api-token
BGC_SOURCE_TOKEN=your-bgc-source-token
BGC_PRIVATE_KEY=your-bgc-private-key
BGC_DEFAULT_REPORT_SKU=basic-criminal
# Public URL base for candidate-facing BGC forms
BGC_PUBLIC_FORM_BASE=https://app.bgc-provider.com/apply
# Set to "true" in production to run real (paid) checks
BGC_LIVE_MODE=false
BGC_WEBHOOK_SECRET=your-bgc-webhook-secret

# =============================================================================
# FACEBOOK / META (Conversion API)
# =============================================================================
FACEBOOK_PIXEL_ID=1234567890
FACEBOOK_CAPI_TOKEN=your-facebook-capi-token
FACEBOOK_APP_SECRET=your-facebook-app-secret
# Only needed for testing events in Meta Events Manager
FACEBOOK_TEST_EVENT_CODE=TEST12345

# =============================================================================
# REDDIT ADS
# =============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REFRESH_TOKEN=your-reddit-refresh-token
REDDIT_USER_AGENT=MCC-AdReporter/1.0

# =============================================================================
# INSTANTLY (cold email outreach)
# =============================================================================
INSTANTLY_API_KEY=your-instantly-api-key

# =============================================================================
# FIREBASE / PUSH NOTIFICATIONS
# =============================================================================
# Full JSON string of the FCM service account credentials
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# =============================================================================
# ADMIN / APP CONFIG
# =============================================================================
# Phone number for SMS alerts sent to the admin on-call
ADMIN_ALERT_PHONE=+15005550006
ADMIN_PHONE_NUMBER=+15005550006
# Password for the admin portal (used by www/admin.html basic auth)
ADMIN_PASSWORD=change-me-in-production
# Slack webhook URL for operational alerts (stall detection, sensitive audit actions)
ADMIN_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Canonical app URL (used for email links, OAuth callbacks, etc.)
MCC_APP_URL=https://app.mycarconcierge.com
PUBLIC_BASE_URL=https://app.mycarconcierge.com
# Return URL for the driver onboarding Stripe Connect flow
DRIVER_APP_RETURN_URL=https://driver.mycarconcierge.com/onboarding/complete

PROVIDER_TEST_PASSWORD=
PROVIDER_B_TEST_EMAIL=
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASS=
REVIEWER_PASSWORD=
# Stripe test-mode keys (tests/care-plan-payment-journey.spec.js)
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_CONNECT_ACCOUNT_ID=
SURVEY_TEST_HOOK_SECRET=
# Smoke/stress runner targets
SMOKE_LOCAL_BASE=
STRESS_TEST_BASE_URL=
STRESS_TEST_PASSWORD=

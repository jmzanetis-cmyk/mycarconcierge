# =============================================================================
# My Car Concierge — .env TEMPLATE (annotated)
# -----------------------------------------------------------------------------
# Generated from a scan of every environment variable the CODE actually reads
# (process.env / Deno.env.get / import.meta.env), cross-referenced with the
# original .env.example.
#
# HOW TO USE:  copy this file to `.env`, fill in real values, never commit `.env`.
#     cp .env.template .env
#
# LEGEND:
#   [REQUIRED]  app expects this in production; missing -> feature breaks
#   [OPTIONAL]  has a fallback / only used by a specific feature
#   [FLAG]      boolean or tuning value; safe defaults if unset
#   [EXTRA]     read by code but NOT in the original .env.example (verify need)
#   [TEST]      only needed to run tests / smoke / stress scripts
#
# Source of truth for these reads: netlify/functions/, server.js, scripts/, lib/
# (the android/, ios/, www/.netlify-deploy/ copies are build artifacts.)
# =============================================================================


# =============================================================================
# SUPABASE  [REQUIRED] — core datastore/auth; read in 200+ places
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-key
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret
# [EXTRA] Supabase CLI token — only used by scripts/run-migrations.js
SUPABASE_ACCESS_TOKEN=sbp_...
# [EXTRA] Direct Postgres connection (pg) — used by car-club-api.js
DATABASE_URL=postgres://user:pass@host:5432/dbname


# =============================================================================
# STRIPE  [REQUIRED] — payments; read in 50+ places
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# [EXTRA][REQUIRED] webhook signature verification — NOT in original example
STRIPE_WEBHOOK_SECRET=whsec_...
# Admin email alerted when the Stripe key nears expiry
STRIPE_KEY_EXPIRY_ADMIN_EMAIL=ops@example.com
# Return URL for the driver Stripe Connect onboarding flow
DRIVER_APP_RETURN_URL=https://driver.mycarconcierge.com/onboarding/complete


# =============================================================================
# ALTERNATE PAYMENT PROVIDERS  [EXTRA][OPTIONAL] — read in server.js
# Fill only if you enable these integrations.
# =============================================================================
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENVIRONMENT=sandbox            # sandbox | production
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ENVIRONMENT=sandbox            # sandbox | production


# =============================================================================
# TWILIO  [REQUIRED] — SMS / Voice / Verify
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public URL Twilio posts inbound SMS/calls to (your Netlify site URL)
TWILIO_INBOUND_PUBLIC_URL=https://your-site.netlify.app
# "true" to validate Twilio webhook signatures in production
TWILIO_SIGNATURE_REQUIRED=true


# =============================================================================
# EMAIL — RESEND  [REQUIRED]
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@example.com      # must be verified in Resend
MCC_FROM_EMAIL=noreply@example.com
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
# Admin destinations for operational alerts (used across ~25 functions)
ADMIN_EMAIL=admin@example.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com
ADMIN_ALERT_EMAIL=admin@example.com


# =============================================================================
# ANTHROPIC / AI AGENTS  [REQUIRED]
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# Secondary key preferred by the agent fleet (ai-ops.js / agent-fleet-runtime.js)
ANTHROPIC_API_KEY_MCC_FLEET1=sk-ant-...
# [FLAG] Minimum confidence (0-1) before an AI action auto-executes
AI_CONFIDENCE_THRESHOLD=0.75
# [FLAG] Max cents the AI may auto-refund without human review
AI_MAX_AUTO_REFUND=5000
# [EXTRA][OPTIONAL] OpenAI integration — server.js
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=


# =============================================================================
# GOOGLE / GEMINI  [REQUIRED for the features that use them]
# =============================================================================
GOOGLE_API_KEY=AIza...
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_VISION_API_KEY=AIza...
GEMINI_API_KEY=AIza...
# [EXTRA][OPTIONAL] distinct keys used by tracking/ETA features
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_ROUTES_API_KEY=AIza...


# =============================================================================
# BACKGROUND CHECKS (BGC)  [REQUIRED if BGC enabled]
# =============================================================================
BGC_API_BASE=https://api.bgc-provider.com/v1
BGC_API_TOKEN=your-bgc-api-token
BGC_SOURCE_TOKEN=your-bgc-source-token
BGC_PRIVATE_KEY=your-bgc-private-key
BGC_DEFAULT_REPORT_SKU=basic-criminal
BGC_PUBLIC_FORM_BASE=https://app.bgc-provider.com/apply
BGC_WEBHOOK_SECRET=your-bgc-webhook-secret
# [FLAG] "true" in production to run real (paid) checks
BGC_LIVE_MODE=false
# [EXTRA][OPTIONAL] Checkr is an alternate BGC provider (server.js)
CHECKR_API_KEY=
CHECKR_ENVIRONMENT=sandbox


# =============================================================================
# CRM / OUTREACH / MARKETING
# =============================================================================
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token   # [REQUIRED if HubSpot]
HUBSPOT_WEBHOOK_SECRET=your-hubspot-webhook-secret         # [EXTRA] webhook verify
APOLLO_API_KEY=your-apollo-api-key                         # lead discovery
INSTANTLY_API_KEY=your-instantly-api-key                   # cold email
INSTANTLY_LIVE=false                                       # [FLAG] send for real
# Merch fulfillment [EXTRA][OPTIONAL] — admin-printful.js
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=


# =============================================================================
# FACEBOOK / META (Conversion API)  [OPTIONAL]
# =============================================================================
FACEBOOK_PIXEL_ID=1234567890
FACEBOOK_CAPI_TOKEN=your-facebook-capi-token
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_TEST_EVENT_CODE=TEST12345          # only for Meta Events Manager testing


# =============================================================================
# REDDIT ADS  [OPTIONAL]
# =============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REFRESH_TOKEN=your-reddit-refresh-token
REDDIT_USER_AGENT=MCC-AdReporter/1.0


# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================
# Full JSON string of the FCM service account credentials [REQUIRED for push]
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# [EXTRA][OPTIONAL] Web Push VAPID public key — server.js
VAPID_PUBLIC_KEY=


# =============================================================================
# ADMIN / APP CONFIG  [REQUIRED]
# =============================================================================
ADMIN_PASSWORD=change-me-in-production          # admin portal (www/admin.html)
ADMIN_ALERT_PHONE=+15005550006
ADMIN_PHONE_NUMBER=+15005550006
ADMIN_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Canonical app URLs (email links, OAuth callbacks, etc.)
MCC_APP_URL=https://app.mycarconcierge.com
PUBLIC_BASE_URL=https://app.mycarconcierge.com
# [EXTRA][OPTIONAL] additional URL/config vars read by code
APP_URL=https://app.mycarconcierge.com
MEMBER_APP_URL=https://app.mycarconcierge.com
SITE_URL=https://app.mycarconcierge.com
COOKIE_SECRET=change-me-cookie-signing-secret   # [EXTRA] admin cookie signing
# [EXTRA] internal service-to-service auth secrets
INTERNAL_API_SECRET=change-me-internal-secret
INTERNAL_SECRET=change-me-internal-secret
ADMIN_API_PASSWORD=change-me
ADMIN_TEAM_TOKENS=                               # comma-separated admin tokens
SCHEDULER_API_KEY=change-me                      # scheduled-job auth
# Email from-address used by broadcast scripts
LAUNCH_FROM_ADDRESS=noreply@example.com


# =============================================================================
# FEATURE FLAGS  [FLAG] — safe defaults if unset
# =============================================================================
FEATURE_WALLET=false
FEATURE_CANCELLATION_POLICY=false
GLOBAL_2FA_ENABLED=false
ENABLE_APPOINTMENT_REMINDERS=false
ENABLE_MAINTENANCE_SCHEDULER=false


# =============================================================================

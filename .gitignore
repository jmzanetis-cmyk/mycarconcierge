# Task #215 — Dev-only files copied by `cap sync` into the mobile bundles.
# The Capacitor CLI doesn't natively support file-level include/exclude,
# so we strip these via scripts/clean-mobile-bundle.sh after every sync.
# Belt-and-braces: if anyone forgets to run the script, these patterns
# also keep the cruft out of git so it can never accidentally re-ship.
ios/App/App/public/.netlify/
ios/App/App/public/.netlify-deploy/
ios/App/App/public/node_modules/
ios/App/App/public/server.js
ios/App/App/public/server.js.backup
ios/App/App/public/package.json
ios/App/App/public/package-lock.json
ios/App/App/public/replit.md
ios/App/App/public/*.bak
ios/App/App/public/*.sql
ios/App/App/public/*.pptx
android/app/src/main/assets/public/.netlify/
android/app/src/main/assets/public/.netlify-deploy/
android/app/src/main/assets/public/node_modules/
android/app/src/main/assets/public/server.js
android/app/src/main/assets/public/server.js.backup
android/app/src/main/assets/public/package.json
android/app/src/main/assets/public/package-lock.json
android/app/src/main/assets/public/replit.md
android/app/src/main/assets/public/*.bak
